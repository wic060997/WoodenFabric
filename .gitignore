# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# --- Angular / Compiled output ---
/dist
/tmp
/out-tsc
/bazel-out
/.angular/cache
/coverage

# --- Node ---
/node_modules
npm-debug.log
yarn-error.log
package-lock.json
# Odkomentuj poniższe, jeśli używasz Yarn:
# yarn.lock

# --- WebStorm / JetBrains IDE ---
# Ignorujemy większość folderu .idea, ale zachowujemy specyficzne ustawienia projektu
.idea/*
!.idea/codeStyles/
!.idea/vcs.xml
!.idea/inspectionProfiles/
!.idea/runConfigurations/
*.iws
out/
build/

# --- Visual Studio Code ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# --- Miscellaneous ---
.sass-cache/
/connect.lock
/libpeerconnection.log
testem.log
/typings
__screenshots__/
.env
.env-custom

# --- System files ---
.DS_Store
Thumbs.db
